{
  "manifest_version": 3,
  "name": "Unofficial \u2014 Dark Mode + Readability",
  "version": "3.0",
  "description": "Dark mode and readability enhancements for Salesforce Marketing Cloud",
  "permissions": [
    "activeTab",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://mc.s7.exacttarget.com/*",
    "https://*.exacttarget.com/*",
    "https://*.marketingcloud.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://mc.s7.exacttarget.com/*",
        "https://*.exacttarget.com/*",
        "https://*.marketingcloud.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}